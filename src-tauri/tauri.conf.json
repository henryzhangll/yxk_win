{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yxiaokao",
  "version": "0.1.0",
  "identifier": "com.wtt.yxiaokao",
  "build": {
      "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "医小考",
        "width": 630,
        "height": 1060,
		"minWidth": 630,
		"minHeight": 1060,
		"resizable":false,
		"maximizable": false,
		"minimizable": false,
		"center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' proxy: data: asset: https: http: 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
